# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# iOS/Xcode
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/ephemeral/
*.xcuserstate

# Android
**/android/.gradle/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.*
**/android/key.properties

# Secrets and local environment files
.env
.env.*
!.env.example
!.env.*.example
*.jks
*.keystore
*.p12
*.pfx
*.pem
*.key
**/google-services.json
**/GoogleService-Info.plist

# Windows
**/windows/flutter/ephemeral/

# macOS
**/macos/Flutter/ephemeral/

# Linux
**/linux/flutter/ephemeral/

# Generated files (if using build_runner with Hive/Freezed)
*.g.dart
*.freezed.dart

# Allow vendored ble_peripheral generated API file(s)
!plugins/ble_peripheral/lib/src/generated/
!plugins/ble_peripheral/lib/src/generated/*.g.dart

# Avoid committing lockfiles from vendored library/example
plugins/ble_peripheral/pubspec.lock

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
